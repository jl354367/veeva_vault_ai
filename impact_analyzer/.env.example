# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket that holds the Configuration Report
S3_CONFIG_BUCKET=your-config-bucket-name
S3_CONFIG_REPORT_KEY=config-reports/latest.json

# Lambda / Step Functions ARN for the AWS analysis agent (Stage 1 & 2)
AWS_AGENT_LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789:function:impact-analyzer-agent
AWS_AGENT_ID=                      # Bedrock Agent ID (if using Bedrock Agents)
AWS_AGENT_ALIAS_ID=                # Bedrock Agent Alias ID

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development                # development | production
MAX_UPLOAD_MB=50
SESSION_TTL_HOURS=24
STORAGE_DIR=storage                # local temp storage for uploads / reports
