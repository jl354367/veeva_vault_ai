# ══════════════════════════════════════════════════════════════════════════════
# VaultBot Help Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════


# ── LLM Backend ───────────────────────────────────────────────────────────────
#
#   demo    → built-in keyword engine (no API key, works offline)
#   bedrock → Amazon Bedrock (real AI — requires AWS credentials below)
#
LLM_BACKEND=demo


# ── Amazon Bedrock ─────────────────────────────────────────────────────────────
#
# STEP 1: Enable Bedrock model access in your AWS account:
#         AWS Console → Amazon Bedrock → Model access → Request access
#
# STEP 2: Create an IAM user or role with this policy:
#         {
#           "Effect": "Allow",
#           "Action": "bedrock:InvokeModel",
#           "Resource": "arn:aws:bedrock:<region>::foundation-model/*"
#         }
#
# STEP 3: Install the AWS SDK:
#         pip install boto3
#
# STEP 4: Fill in the values below and set LLM_BACKEND=bedrock
#
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Model to use — choose one from the list below:
#   anthropic.claude-3-5-sonnet-20241022-v2:0   ← recommended (best quality)
#   anthropic.claude-3-5-haiku-20241022-v1:0    ← faster / cheaper
#   anthropic.claude-3-haiku-20240307-v1:0
#   anthropic.claude-3-sonnet-20240229-v1:0
#   amazon.titan-text-express-v1
#   meta.llama3-8b-instruct-v1:0
#   meta.llama3-70b-instruct-v1:0
#   mistral.mistral-7b-instruct-v0:2
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Max tokens for model response (increase for longer answers)
BEDROCK_MAX_TOKENS=2048


# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
